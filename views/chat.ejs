<!DOCTYPE html>
<html lang="en">

<head>
    <title>ButterDog Chat</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Login to ButterDog Chat">
    <meta name="og:description" content="Login to ButterDog Chat">
    <meta name="author" content="ButterDogCo">
    <link rel="stylesheet" href="./css/chat.css">
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200">
    <link rel="shortcut icon" href="./favicon.ico">
</head>

<body>
    <main class="container" id="main-container">
        <section class="sidebar-container">
            <button class="text-button" id="new-conversation-button">New Conversation...</button>
            <ul class="conversations" id="conversation-list"></ul>
            <div class="account">
                <div class="user-avatar" data-self="true">
                    <%= user.username.charAt(0).toUpperCase() %>
                </div>
                <p>
                    <%= user.username %>
                </p>
                <button class="icon-button" onclick="logout()" title="Logout"><span
                        class="material-symbols-rounded">logout</span></button>
            </div>
        </section>
        <section class="member-list-container">
            <ul class="member-list" id="member-list"></ul>
        </section>
        <section class="content-container">
            <div class="conversation-header">
                <h2 id="conversation-title">No active conversation</h2>
                <div class="buttons">
                    <button class="icon-button" title="Edit group name" id="edit-group-name-button"><span
                            class="material-symbols-rounded">edit</span></button>
                    <button class="icon-button" title="Add member" id="add-member-button"><span
                            class="material-symbols-rounded">person_add</span></button>
                    <button class="icon-button" title="Toggle member list" id="toggle-member-list-button"><span
                            class="material-symbols-rounded">patient_list</span></button>
                </div>
            </div>
            <div class="messages" id="message-container" tabindex="0" aria-live="polite"></div>
            <p class="typing-indicator" id="typing-indicator"></p>
        </section>
        <section class="input-container">
            <form class="form" id="input-form">
                <textarea type="text" placeholder="Enter message" class="message-input text-input" id="message-input"
                    autocomplete="off" maxlength="<%= messageMaxLength %>"></textarea>
                <button class="message-send text-button" type="button" id="send-button">Send</button>
            </form>
        </section>
    </main>

    <div class="notifications" id="notifications-container"></div>

    <div class="modal" id="user-select-modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="user-select-title">New Conversation</h3>
                <button class="close-button" id="user-select-close-button">&times;</button>
            </div>

            <div class="modal-body">
                <input class="text-input" type="text" id="user-search-input" placeholder="Search for a user"
                    autocomplete="off">

                <div id="user-search-results" class="search-results"></div>
                <button class="create-button text-button" id="user-select-submit-button"><span
                        id="user-select-submit-button-text">Create Conversation</span> (<span
                        id="user-select-selected-count">0</span> selected)</button>
            </div>
        </div>
    </div>

    <script>
        const currentUser = {
            id: '<%= user.id %>',
            username: '<%= user.username %>',
            colorHue: '<%= user.colorHue %>'
        };
        const constants = {
            MESSAGE_EDIT_WINDOW: <%= messageEditWindow %>
        };
    </script>

    <script src="/socket.io/socket.io.js"></script>
    <script src="js/chat.js"></script>
    <script src="js/auth.js"></script>
</body>

</html>